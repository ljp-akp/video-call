<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>图片展示</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html,body{
    width:100%;
    height:100%;
    background:#000;
}

img{
    width:100%;
    height:100%;
    object-fit:contain;
    display:block;
}
</style>
</head>

<body>

<img src="IMG_5813.png" alt="图片">

</body>
</html>
